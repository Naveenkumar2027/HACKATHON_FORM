# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# MongoDB (optional – if set, registrations are stored in Atlas)
# Atlas: Network Access → add 0.0.0.0/0 so Vercel can connect.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.XXXXX.mongodb.net/"
MONGODB_DB_NAME="hackathon"

# Alternative: Vercel Blob (no MongoDB needed). In Vercel Dashboard → Storage → Create Blob store.
# BLOB_READ_WRITE_TOKEN is auto-added when you create the store. If MongoDB fails, registrations save to Blob.

# Optional: API base URL for frontend (leave empty when same origin, e.g. on Vercel)
# VITE_API_BASE=
