# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# Registration storage: Vercel Blob (store: wiredweekend-form-blob).
# In Vercel: Settings → Environment Variables → add BLOB_READ_WRITE_TOKEN = your blob token (no quotes).
# Apply to Production and Preview. Redeploy after adding.

# Optional: API base URL for frontend (leave empty when same origin, e.g. on Vercel)
# VITE_API_BASE=

# n8n: Webhook URL for sending confirmation email after registration.
# In n8n: workflow must be ACTIVE (toggle on in top-right) for production URL to work.
# Local: copy to .env and set N8N_WEBHOOK_URL. Vercel: add to Environment Variables, then redeploy.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/cdb6a9c7-6046-4c96-a35f-2b8fa4e71beb
