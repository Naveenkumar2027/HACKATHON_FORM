# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# MongoDB (required for registration API and Vercel)
# 1. Go to https://cloud.mongodb.com → your cluster → Connect → Drivers
# 2. Copy the URI; it must look like: mongodb+srv://USER:PASSWORD@cluster0.XXXXX.mongodb.net/
#    (real host is cluster0.xxxxx.mongodb.net, NOT cluster.mongodb.net)
# 3. Replace USER and PASSWORD with your Atlas database user. On Vercel, set MONGODB_URI in Project → Settings → Environment Variables.
MONGODB_URI=mongodb+srv://thequantumbugs_db_user:aO2MdCDUSdly7psQ@cluster0.1qxnoig.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=thequantumbugs_db_user

# Optional: API base URL for frontend (leave empty when same origin, e.g. on Vercel)
# VITE_API_BASE=
